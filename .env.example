PORT=3000

# Telegram
TELEGRAM_BOT_TOKEN=xxx
TELEGRAM_CHAT_ID=123456789

# Binance public endpoints work without keys for signals.
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# Bot
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
DEFAULT_LEVERAGE=10
TRADING_ENABLED=false
TRADE_MODE=SPOT

# Hız / gecikmesiz takip
SCAN_INTERVAL=5m
SCAN_EVERY_SECONDS=30
FOLLOW_REPORT_SECONDS=45
URGENT_REPEAT_SECONDS=90
MARKET_SUMMARY_MINUTES=10

# Ön uyarı + onaylı sinyal
WATCH_ALERT_SCORE=55
WATCH_ALERT_COOLDOWN_SECONDS=180
SIGNAL_THRESHOLD=88
ENTRY_APPROVAL_SCORE=88

# V4/V5 risk azaltma filtreleri
MIN_ENTRY_VOLUME_RATIO=0.65
BREAKOUT_VOLUME_RATIO=0.75
NEAR_LEVEL_BLOCK_PERCENT=0.8
MTF_MID_CONFIRM_SCORE=58
REVERSAL_WARN_SCORE=75
REVERSAL_EXIT_SCORE=85
REVERSAL_GAP_WARN=6
REVERSAL_GAP_EXIT=12
PROFIT_GIVEBACK_WARN=0.45
PROFIT_GIVEBACK_EXIT=0.90
AUTO_CLOSE_ON_EXIT_SIGNAL=false

# OpenAI opsiyonel. Bot OpenAI olmadan devam eder.
OPENAI_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_DAILY_MAX_CALLS=20
OPENAI_MONTHLY_MAX_CALLS=500
OPENAI_MAX_OUTPUT_TOKENS=250

# Fırsat radarı: gerçek sinyalden önce en yakın adayları bildirir
OPPORTUNITY_RADAR_ENABLED=true
OPPORTUNITY_RADAR_MINUTES=15

# 1 HAFTALIK PAPER TEST / RAPOR MODU
AUTO_PAPER_TRADING=true
PAPER_OPEN_NOTIFY=false
PAPER_ALLOW_MULTIPLE_PER_SYMBOL=false
WEEKLY_REPORT_ENABLED=true
REPORT_EVERY_HOURS=24
REPORT_DAYS=7
REPORT_SEND_EMPTY=false

# Güvenli mod: gerçek emir açmaz, sadece paper trade ve plan üretir
TRADING_ENABLED=false
AUTO_MODE=false
PAPER_TRADING=true
REQUIRE_ENTRY_TRIGGER=true


# Pullback giriş modu: breakout beklemeden EMA21/destek-direnç dönüşünü de test eder
ENABLE_PULLBACK_ENTRY=true
PULLBACK_MIN_VOLUME_RATIO=0.75
PULLBACK_MAX_DISTANCE_PERCENT=0.85

SWING_MIN_SCORE=70
SWING_MIN_CONFIDENCE=60
SWING_MIN_VOLUME_RATIO=0.65
SWING_MIN_RR=1.5
RADAR_ONLY_TOP=3
# ENTRY V3 - kademeli giriş
EARLY_ENTRY_SCORE=60
PREPARE_ENTRY_SCORE=75
EARLY_MIN_VOLUME_RATIO=0.55
PULLBACK_ENTRY_ZONE_PERCENT=0.22
BREAKOUT_ENTRY_ZONE_PERCENT=0.14